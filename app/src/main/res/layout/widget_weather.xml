<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:paddingStart="16dp"
    android:paddingTop="15dp"
    android:paddingEnd="15dp"
    android:paddingBottom="15dp">

    <ImageView
        android:id="@+id/refresh_button"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:alpha="0.92"
        android:contentDescription="Refresh"
        android:src="@drawable/ic_refresh_24"
        android:tint="@color/widget_icon_tint" />

    <LinearLayout
        android:id="@+id/weather_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <!-- Left Side: Clock, Date and Forecast -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.12"
            android:gravity="top|start"
            android:orientation="vertical">

            <TextClock
                android:id="@+id/clock_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:format12Hour="h:mm"
                android:format24Hour="HH:mm"
                android:gravity="start"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="--:--"
                android:textColor="@color/widget_text_primary"
                android:textSize="52sp"
                android:fontFamily="sans-serif"
                android:shadowColor="@color/widget_text_shadow"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="4"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/date_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="viernes, 28 nov"
                android:textColor="@color/widget_text_secondary"
                android:textSize="15sp"
                android:fontFamily="sans-serif"
                android:includeFontPadding="false"
                android:shadowColor="@color/widget_text_shadow"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="2.5" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">
                
                <TextView
                    android:id="@+id/forecast_day1_text"
                    android:layout_width="46dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text=""
                    android:textColor="@color/widget_text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif"
                    android:gravity="center"
                    android:lineSpacingExtra="0dp"
                    android:shadowColor="@color/widget_text_shadow"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="2.2" />

                <TextView
                    android:id="@+id/forecast_day2_text"
                    android:layout_width="46dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text=""
                    android:textColor="@color/widget_text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif"
                    android:gravity="center"
                    android:lineSpacingExtra="0dp"
                    android:shadowColor="@color/widget_text_shadow"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="2.2" />

                <TextView
                    android:id="@+id/forecast_day3_text"
                    android:layout_width="46dp"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/widget_text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif"
                    android:gravity="center"
                    android:lineSpacingExtra="0dp"
                    android:shadowColor="@color/widget_text_shadow"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="2.2" />
            </LinearLayout>
        </LinearLayout>

        <!-- Right Side: Weather -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.88"
            android:gravity="center_vertical|end"
            android:paddingTop="13dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/location_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textColor="@color/widget_text_primary"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:includeFontPadding="false"
                android:shadowColor="@color/widget_text_shadow"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="2.8"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                
                <TextView
                    android:id="@+id/weather_icon_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="9dp"
                    android:text="--"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="36sp"
                    android:fontFamily="sans-serif"
                    android:shadowColor="@color/widget_text_shadow"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="3" />

                <TextView
                    android:id="@+id/temperature_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--°"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="40sp"
                    android:fontFamily="sans-serif"
                    android:includeFontPadding="false"
                    android:shadowColor="@color/widget_text_shadow"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="3.5"
                    android:textStyle="bold" />
                    
                <TextView
                    android:id="@+id/feels_like_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="ST: --°"
                    android:textColor="@color/widget_text_secondary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:includeFontPadding="false"
                    android:shadowColor="@color/widget_text_shadow"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="2.4" />
            </LinearLayout>

            <TextView
                android:id="@+id/condition_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="--"
                android:textColor="@color/widget_text_secondary"
                android:textSize="14sp"
                android:fontFamily="sans-serif"
                android:includeFontPadding="false"
                android:shadowColor="@color/widget_text_shadow"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="2.4" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="9dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/min_temp_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="15dp"
                    android:text="Min: --°"
                    android:textColor="@color/widget_text_tertiary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif"
                    android:includeFontPadding="false"
                    android:shadowColor="@color/widget_text_shadow"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="2.2" />

                <TextView
                    android:id="@+id/max_temp_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Max: --°"
                    android:textColor="@color/widget_text_tertiary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif"
                    android:includeFontPadding="false"
                    android:shadowColor="@color/widget_text_shadow"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="2.2" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
