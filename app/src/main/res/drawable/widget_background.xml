<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <corners android:radius="18dp" />
            <gradient
                android:angle="0"
                android:startColor="#70101828"
                android:centerColor="#46192333"
                android:endColor="#8F070A12" />
            <stroke
                android:width="1dp"
                android:color="#2EFFFFFF" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape>
            <corners android:radius="17dp" />
            <gradient
                android:angle="270"
                android:startColor="#30FFFFFF"
                android:centerColor="#08000000"
                android:endColor="#22000000" />
        </shape>
    </item>
</layer-list>
